# Server Configuration
PORT=5000
NODE_ENV=development
HOST=localhost

# Database - PostgreSQL
# Use this format for PostgreSQL (Required for Docker)
DATABASE_URL=postgresql://user:password@localhost:5432/dbname
# POSTGRES_URL can also be used as fallback
# POSTGRES_URL=postgresql://user:password@host:port/dbname

# Legacy SQLite (Not recommended for production)
# DATABASE_URL=file:./database.db
# DATABASE_PATH=./database.db

# JWT Secret (Generate a strong secret key, min 32 chars)
JWT_SECRET=your-very-secure-jwt-secret-key-here-minimum-32-chars

# SMTP Configuration (Gmail example)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-specific-password

# OpenAI API Configuration
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_ORGANIZATION=your-openai-org-id-here
GAPGPT_API_KEY=your-gapgpt-api-key-here
GAPGPT_BASE_URL=https://api.gapgpt.app/v1
GAPGPT_MODEL=gapgpt-qwen-3.5

# Anthropic Claude API Configuration
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Google AI (Gemini) API Configuration
GOOGLE_AI_API_KEY=your-google-ai-api-key-here

# Perplexity API Configuration
PERPLEXITY_API_KEY=your-perplexity-api-key-here

# Bale Bot Configuration
BALE_BOT_TOKEN=your-bale-bot-token-here
BALE_API_URL=https://api.bale.ai/v1
BALE_API_BASE=https://tapi.bale.ai/bot

# SMS.ir Configuration
SMS_IR_API_KEY=your-sms-ir-api-key-here
SMS_IR_TEMPLATE_ID=your-sms-template-id-here

# Rasmio API Configuration
RASMIO_API_KEY=your-rasmio-api-key-here
RASMIO_API_URL=https://api.rasmio.ir

# Application Settings
APP_NAME="صندوق پژوهش و فناوری گیلان"
APP_URL=http://localhost:5000
FRONTEND_URL=http://localhost:5173
CLIENT_URL=http://localhost:5173

# Upload Settings
MAX_FILE_SIZE=10485760
UPLOAD_DIR=./uploads

# Session Settings
SESSION_SECRET=your-session-secret-key-here-minimum-32-chars
SESSION_EXPIRY=24h

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Logging
LOG_LEVEL=info
LOG_DIR=./logs

# AI Models Configuration (Optional - for advanced users)
# Default models will be used if not specified
AI_DEFAULT_MODEL=claude-3-5-sonnet
AI_TEMPERATURE=0.2
AI_MAX_TOKENS=4000

# Claude AI Advanced Configuration
CLAUDE_MODEL=claude-sonnet-4-20250514
CLAUDE_MAX_TOKENS=8000

# Cache Configuration
ENABLE_CACHE=true
CACHE_TTL=3600

# Security
CORS_ORIGIN=http://localhost:5173
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5000

# Feature Flags
ENABLE_AI_ANALYSIS=true
ENABLE_BALE_INTEGRATION=true
ENABLE_SMS_OTP=true
ENABLE_EMAIL_NOTIFICATIONS=true
ENABLE_AI_VARIABLE_DETECTION=true

# Development Settings (Only for development)
DEV_MODE=true
DEBUG=false
MOCK_SERVICES=false
